# Archivos grandes de imágenes (mantener solo los nombres en INSTRUCCIONES)
# Las imágenes reales deben subirse manualmente si son necesarias
# Descomenta la siguiente línea si quieres ignorar todas las imágenes:
# imagenes/*.jpg
# imagenes/*.jpeg
# imagenes/*.png
# imagenes/*.webp

# Mantener solo el archivo de instrucciones en imagenes/
!imagenes/.gitkeep
!imagenes/INSTRUCCIONES_IMAGENES.txt

